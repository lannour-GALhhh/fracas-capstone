# Copy to .env and fill in real values. .env is gitignored — never commit it.

# --- DATABASE (PostGIS) ---
POSTGRES_DB=fracas_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
DB_NAME=fracas_db
DB_USER=postgres
DB_PASSWORD=change-me
DB_HOST=db
DB_PORT=5432

# --- REDIS / CELERY ---
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0

# --- DJANGO ---
SECRET_KEY=change-me-generate-a-real-key
# DEBUG must be False in production (enables the security hardening block).
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# --- LOGGING / THROTTLING ---
LOG_LEVEL=INFO
THROTTLE_USER=2000/hour
THROTTLE_ANON=200/hour

# --- PRODUCTION SECURITY (only applied when DEBUG=False) ---
# Redirect HTTP->HTTPS (disable if a proxy already does it / for internal probes).
SECURE_SSL_REDIRECT=True
# HSTS max-age in seconds; leave 0 until HTTPS is confirmed stable, then e.g. 31536000.
SECURE_HSTS_SECONDS=0

# --- FRONTEND ---
VITE_API_URL=http://localhost

# --- ALERTING PROVIDERS ---
# SMS_PROVIDER: console (dev, logs only) | twilio | semaphore
SMS_PROVIDER=console
# PUSH_PROVIDER: console (dev, logs only) | fcm
PUSH_PROVIDER=console

# Twilio (only if SMS_PROVIDER=twilio)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM=

# Semaphore (only if SMS_PROVIDER=semaphore)
# SEMAPHORE_API_KEY=
# SEMAPHORE_SENDER_NAME=

# FCM (only if PUSH_PROVIDER=fcm) — path to a service-account JSON
# FCM_CREDENTIALS_FILE=

# --- Media storage (report evidence images, etc.) ---
# MEDIA_STORAGE: local (default, filesystem) | s3 | cloudinary
MEDIA_STORAGE=local

# S3 / S3-compatible (only if MEDIA_STORAGE=s3)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_STORAGE_BUCKET_NAME=
# AWS_S3_REGION_NAME=
# AWS_S3_ENDPOINT_URL=          # for MinIO / non-AWS S3
# AWS_QUERYSTRING_AUTH=True

# Cloudinary (only if MEDIA_STORAGE=cloudinary)
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
